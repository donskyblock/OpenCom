# OpenCom dedicated media environment
# Not a production Cloud Run fit because mediasoup needs its RTC port range exposed.

NODE_ENV=production

# Cloud Run injects PORT automatically for plain HTTP, but production voice should run on GCE/GKE instead.
MEDIA_PORT=3003
MEDIA_HOST=0.0.0.0

# Database
MEDIA_DATABASE_URL=mysql://opencom:password@127.0.0.1:3306/ods_node

# Core / auth integration
CORE_BASE_URL=https://core.example.com
MEDIA_SERVER_URL=https://media.example.com
MEDIA_WS_URL=wss://media.example.com/gateway
MEDIA_ALLOWED_ORIGINS=https://app.example.com,https://panel.example.com
MEDIA_TOKEN_SECRET=replace_me_media_token_secret
MEDIA_TOKEN_ISSUER=opencom-media
MEDIA_TOKEN_AUDIENCE=
MEDIA_SYNC_SECRET=replace_me_shared_node_sync_secret

# mediasoup networking
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_ADDRESS=media.example.com
MEDIASOUP_ENABLE_UDP=1
MEDIASOUP_ENABLE_TCP=1
MEDIASOUP_PREFER_UDP=1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100

# Logging
LOG_LEVEL=warn
LOG_DIR=./logs
LOG_TO_FILE=0
DEBUG_HTTP=0
DEBUG_VOICE=0
