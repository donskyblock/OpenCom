# Core API loads this file from backend/.env (not frontend). Copy to backend/.env and set values.
# CORE
NODE_ENV=production
PORT=3000
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# Object storage: local filesystem (default) or S3-compatible bucket.
# With IAM role auth on EC2, keep S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY empty.
STORAGE_PROVIDER=local
CORE_S3_BUCKET=opencom-core-uploads
NODE_S3_BUCKET=opencom-node
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=0
S3_KEY_PREFIX=
CORE_GATEWAY_HOST=0.0.0.0
CORE_GATEWAY_PORT=9443
# Set both files to enable native TLS/WSS on gateway port
CORE_GATEWAY_TLS_CERT_FILE=
CORE_GATEWAY_TLS_KEY_FILE=
# Official server node (for "Create your server") - required in backend/.env only
OFFICIAL_NODE_BASE_URL=http://localhost:3002
OFFICIAL_NODE_SERVER_ID=my-node-1
# Shared secret for core -> node internal APIs. Set NODE_SYNC_SECRET below to the same value.
CORE_NODE_SYNC_SECRET=replace_me_shared_node_sync_secret
# Run `node scripts/create-private-calls-guild.mjs` once after the node is up, then paste the returned guild ID here.
PRIVATE_CALLS_GUILD_ID=
CORE_LOG_LEVEL=warn
CORE_LOG_DIR=./logs
CORE_LOG_TO_FILE=1
# Optional deployment metadata used by the staff panel infrastructure view.
# For this AWS-hosted install, set the values below to match your EC2 environment.
DEPLOYMENT_PROVIDER=aws
DEPLOYMENT_COMPUTE_CLASS=ec2
DEPLOYMENT_REGION=eu-north-1
DEPLOYMENT_STACK_NAME=opencom-production
DEPLOYMENT_OS_NAME=ubuntu
CORE_JWT_ACCESS_SECRET=replace_me_access_secret
CORE_JWT_REFRESH_SECRET=replace_me_refresh_secret

# Core membership signing (RS256)
CORE_MEMBERSHIP_PRIVATE_JWK='{"kty":"RSA","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"...","kid":"core-1"}'
CORE_MEMBERSHIP_PUBLIC_JWK='{"kty":"RSA","n":"...","e":"AQAB","kid":"core-1"}'
CORE_ISSUER=https://core.local
ADMIN_PANEL_PASSWORD=replace_with_long_admin_panel_password
ADMIN_2FA_ENCRYPTION_KEY=replace_with_long_random_key
ADMIN_2FA_ISSUER=OpenCom Admin

# SERVER NODE
NODE_PORT=3002
NODE_HOST=0.0.0.0
NODE_DATABASE_URL=mysql://db_user:db_password@127.0.0.1:3306/ods_node
NODE_ID=node-local-1
NODE_SERVER_ID=my-node-1
CORE_BASE_URL=http://localhost:3000
CORE_JWKS_URL=http://localhost:3000/v1/jwks
# Must match CORE_NODE_SYNC_SECRET above so the node accepts private-call provisioning requests.
NODE_SYNC_SECRET=replace_me_shared_node_sync_secret
# Dedicated media service used for direct voice signaling/WebRTC.
# MEDIA_WS_URL is returned to clients and should point at the public ws/wss endpoint.
MEDIA_SERVER_URL=http://localhost:3003
MEDIA_WS_URL=ws://localhost:3003/gateway
MEDIA_TOKEN_SECRET=replace_me_media_token_secret
MEDIA_TOKEN_ISSUER=opencom-media
MEDIA_TOKEN_AUDIENCE=
MEDIA_TOKEN_TTL_SECONDS=300
# Must match MEDIA_SYNC_SECRET on the dedicated media instance so the app/node
# service can push disconnects, room closes and mute/deafen state updates.
MEDIA_SYNC_SECRET=replace_me_shared_node_sync_secret
# ICE defaults returned to clients during VOICE_JOIN.
VOICE_STUN_URLS=stun:stun.l.google.com:19302
# Optional TURN relay URLs, comma-separated.
# Example:
# VOICE_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp
VOICE_TURN_URLS=
# Shared secret for coturn-style static-auth-secret deployments.
VOICE_TURN_SECRET=
# Lifetime for generated TURN credentials.
VOICE_TURN_TTL_SECONDS=3600
LOG_LEVEL=warn
LOG_DIR=./logs
LOG_TO_FILE=1

ATTACHMENT_MAX_BYTES=52428800
ATTACHMENT_BOOST_MAX_BYTES=104857600
CLIENT_UPLOAD_MAX_BYTES=524288000
ATTACHMENT_TTL_DAYS=365
ATTACHMENT_STORAGE_DIR=./data/attachments
PUBLIC_BASE_URL=http://localhost:3002

# mediasoup/networking for the dedicated media service (and legacy node voice fallback if still used)
# Set MEDIASOUP_ANNOUNCED_ADDRESS to the media instance's public IP or hostname when clients connect over the internet.
# If left blank, OpenCom will try to infer it from MEDIA_SERVER_URL/PUBLIC_BASE_URL when that host is not loopback.
# Legacy MEDIASOUP_ANNOUNCED_IP is still accepted, but MEDIASOUP_ANNOUNCED_ADDRESS is preferred.
# The full MEDIASOUP_RTC_MIN_PORT-MEDIASOUP_RTC_MAX_PORT range must be reachable over UDP and TCP.
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_ADDRESS=
# MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_ENABLE_UDP=1
MEDIASOUP_ENABLE_TCP=1
MEDIASOUP_PREFER_UDP=1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
MEDIA_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# REDIS
REDIS_URL=redis://localhost:6379

# STRIPE (OpenCom Boost: £10/month)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_BOOST_GBP_10=
STRIPE_SUCCESS_URL=http://localhost:5173/?billing=success
STRIPE_CANCEL_URL=http://localhost:5173/?billing=cancel
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:5173/

# KLIPY media search (optional, used by the in-app GIF picker)
KLIPY_API_KEY=
KLIPY_API_BASE_URL=https://api.klipy.com
# Optional client identifier forwarded to Klipy on v2 requests
KLIPY_CLIENT_KEY=opencom-web

# Email delivery (generic SMTP example; AWS SES works here too)
AUTH_REQUIRE_EMAIL_VERIFICATION=1
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
APP_BASE_URL=http://localhost:5173
SUPPORT_BASE_URL=http://localhost:5174
SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=no.reply@opencom.online
# Optional SMTP debugging:
# SMTP_DEBUG_LOGGING=1
# SMTP_DEBUG_VERIFY_BEFORE_SEND=1
# Optional aliases also supported by backend mailer:
# ZOHO_EMAIL=your-zoho-user@yourdomain.com
# ZOHO_APP_PASSWORD=your-zoho-app-password
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=587
# ZOHO_SMTP_SECURE=0

oauth_sync_secret=CHANGE_ME
