ATTACHMENT_MAX_BYTES=52428800
ATTACHMENT_TTL_DAYS=365
ATTACHMENT_STORAGE_DIR=./data/attachments
PUBLIC_BASE_URL=http://localhost:3002
NODE_SERVER_ID=my-node-1
# Set MEDIASOUP_ANNOUNCED_ADDRESS to the node's public IP or hostname when clients connect over the internet.
# If left blank, OpenCom will try to infer it from PUBLIC_BASE_URL when that host is not loopback.
# Legacy MEDIASOUP_ANNOUNCED_IP is still accepted, but MEDIASOUP_ANNOUNCED_ADDRESS is preferred.
# The full MEDIASOUP_RTC_MIN_PORT-MEDIASOUP_RTC_MAX_PORT range must be reachable over UDP and TCP.
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_ADDRESS=
# MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_ENABLE_UDP=1
MEDIASOUP_ENABLE_TCP=1
MEDIASOUP_PREFER_UDP=1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
LOG_LEVEL=warn
LOG_DIR=./logs
LOG_TO_FILE=1
