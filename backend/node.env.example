# OpenCom server-node environment
# Cloud Run can host the HTTP API, but production voice/media networking still usually belongs on GCE or GKE.

NODE_ENV=production

# Cloud Run injects PORT automatically.
NODE_PORT=3002
NODE_HOST=0.0.0.0

# Database
NODE_DATABASE_URL=mysql://opencom:password@127.0.0.1:3306/ods_node
NODE_ID=node-gcp-1
NODE_SERVER_ID=my-node-1

# Core integration
CORE_BASE_URL=https://core.example.com
CORE_JWKS_URL=https://core.example.com/v1/jwks
NODE_SYNC_SECRET=replace_me_shared_node_sync_secret

# Public/API URLs
PUBLIC_BASE_URL=https://node.example.com
MEDIA_SERVER_URL=https://media.example.com
MEDIA_WS_URL=wss://media.example.com/gateway
MEDIA_TOKEN_SECRET=replace_me_media_token_secret
MEDIA_TOKEN_ISSUER=opencom-media
MEDIA_TOKEN_AUDIENCE=
MEDIA_TOKEN_TTL_SECONDS=300
MEDIA_SYNC_SECRET=replace_me_shared_node_sync_secret

# Storage
STORAGE_PROVIDER=s3
NODE_S3_BUCKET=opencom-node-uploads
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=0
S3_KEY_PREFIX=
ATTACHMENT_MAX_BYTES=52428800
ATTACHMENT_BOOST_MAX_BYTES=104857600
ATTACHMENT_TTL_DAYS=365
ATTACHMENT_STORAGE_DIR=./data/attachments

# Voice / TURN
VOICE_STUN_URLS=stun:stun.l.google.com:19302
VOICE_TURN_URLS=
VOICE_TURN_SECRET=
VOICE_TURN_TTL_SECONDS=3600

# mediasoup networking
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_ADDRESS=
MEDIASOUP_ENABLE_UDP=1
MEDIASOUP_ENABLE_TCP=1
MEDIASOUP_PREFER_UDP=1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100

# Logging
LOG_LEVEL=warn
LOG_DIR=./logs
LOG_TO_FILE=0
DEBUG_HTTP=0
DEBUG_VOICE=0
