# OpenCom Core API environment
# Good fit for Cloud Run on GCP.

NODE_ENV=production

# Cloud Run injects PORT automatically. Keep CORE_PORT unset there unless you have a reason to override.
CORE_PORT=3000
CORE_HOST=0.0.0.0
CORE_GATEWAY_HOST=0.0.0.0
CORE_GATEWAY_PORT=9443
CORE_GATEWAY_TLS_CERT_FILE=
CORE_GATEWAY_TLS_KEY_FILE=

# Cloud SQL / DB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=opencom
DB_PASSWORD=
DB_NAME=ods_core

# Redis / Memorystore
# Set REDIS_DISABLED=1 to skip Redis for initial deployments (single-instance only).
REDIS_DISABLED=0
REDIS_URL=redis://127.0.0.1:6379

# Logging
CORE_LOG_LEVEL=warn
CORE_LOG_DIR=./logs
CORE_LOG_TO_FILE=0

# Optional deployment metadata shown in admin/staff views
DEPLOYMENT_PROVIDER=gcp
DEPLOYMENT_COMPUTE_CLASS=cloud-run
DEPLOYMENT_REGION=europe-west2
DEPLOYMENT_STACK_NAME=opencom-production
DEPLOYMENT_OS_NAME=linux

# Auth / signing
CORE_JWT_ACCESS_SECRET=replace_me_access_secret
CORE_JWT_REFRESH_SECRET=replace_me_refresh_secret
CORE_MEMBERSHIP_PRIVATE_JWK='{"kty":"RSA","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"...","kid":"core-1"}'
CORE_MEMBERSHIP_PUBLIC_JWK='{"kty":"RSA","n":"...","e":"AQAB","kid":"core-1"}'
CORE_ISSUER=https://core.example.com
ADMIN_PANEL_PASSWORD=replace_with_long_admin_panel_password
ADMIN_2FA_ENCRYPTION_KEY=replace_with_long_random_key
ADMIN_2FA_ISSUER=OpenCom Admin

# Storage
# GCP-native path: use Cloud Storage with runtime service-account IAM permissions.
STORAGE_PROVIDER=gcs
CORE_STORAGE_BUCKET=opencom-core-uploads
GCS_PROJECT_ID=
# Legacy S3-compatible path if you still need it.
CORE_S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=0
S3_KEY_PREFIX=
PROFILE_IMAGE_STORAGE_DIR=./storage/profiles
# Keep this pointed at the backend proxy route, not a bucket URL.
PROFILE_IMAGE_BASE_URL=/v1/profile-images
ATTACHMENT_MAX_BYTES=52428800
ATTACHMENT_BOOST_MAX_BYTES=104857600
CLIENT_UPLOAD_MAX_BYTES=524288000
ATTACHMENT_TTL_DAYS=365
ATTACHMENT_STORAGE_DIR=./data/attachments

# Node/media integration
OFFICIAL_NODE_BASE_URL=https://node.example.com
OFFICIAL_NODE_SERVER_ID=my-node-1
CORE_NODE_SYNC_SECRET=replace_me_shared_node_sync_secret
PRIVATE_CALLS_GUILD_ID=
MEDIA_SERVER_URL=https://media.example.com
MEDIA_WS_URL=wss://media.example.com/gateway
MEDIA_TOKEN_SECRET=replace_me_media_token_secret
MEDIA_TOKEN_ISSUER=opencom-media
MEDIA_TOKEN_AUDIENCE=
MEDIA_TOKEN_TTL_SECONDS=300

# Billing / app URLs
APP_BASE_URL=https://app.example.com
SUPPORT_BASE_URL=https://support.example.com
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_BOOST_GBP_10=
STRIPE_SUCCESS_URL=https://app.example.com/?billing=success
STRIPE_CANCEL_URL=https://app.example.com/?billing=cancel
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://app.example.com/

# Email
AUTH_REQUIRE_EMAIL_VERIFICATION=1
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=60
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Optional integrations
KLIPY_API_KEY=
KLIPY_API_BASE_URL=https://api.klipy.com
KLIPY_CLIENT_KEY=opencom-web
DOWNLOADS_STORAGE_DIR=frontend/public/downloads
